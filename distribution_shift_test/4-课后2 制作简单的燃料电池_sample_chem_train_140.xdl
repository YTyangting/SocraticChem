<?xml version="1.0" encoding="UTF-8"?>
<XDL>
  <Metadata 
    title="Na2SO4溶液电解与导电性实验" 
    goal="观察Na2SO4溶液电解时的气泡产生和颜色变化，并验证溶液的导电性" 
    difficulty="Normal"
  />
  <Synthesis>
    <Hardware>
      <Component id="graduated_cylinder_1" type="graduated_cylinder" capacity="100ml"/>
      <Component id="u_tube_1" type="u_tube" capacity="50ml"/>
      <Component id="dropper_1" type="dropper"/>
      <Component id="graphite_rod_1" type="electrode"/>
      <Component id="graphite_rod_2" type="electrode"/>
      <Component id="dc_power_1" type="dc_power_supply"/>
      <Component id="wire_1" type="wire"/>
      <Component id="wire_2" type="wire"/>
      <Component id="switch_k1" type="switch"/>
      <Component id="ammeter_1" type="ammeter"/>
      <Component id="led_1" type="led"/>
      <Component id="music_box_1" type="music_box"/>
      <Component id="switch_k2" type="switch"/>
      <Component id="stand_1" type="stand"/>
    </Hardware>
    <Reagents>
      <Reagent name="Na2SO4_solution" state="liquid"/>
      <Reagent name="phenolphthalein_solution" state="liquid"/>
    </Reagents>
    <Procedure>
      <Add vessel="graduated_cylinder_1" reagent="Na2SO4_solution" volume="30 mL"/>
      <Transfer from_vessel="graduated_cylinder_1" to_vessel="u_tube_1" volume="30 mL"/>
      <Add vessel="u_tube_1" reagent="phenolphthalein_solution" volume="2 mL" tool="dropper_1"/>
      <Add vessel="u_tube_1" reagent="phenolphthalein_solution" volume="2 mL" tool="dropper_1"/>
      <Insert tool="graphite_rod_1" vessel="u_tube_1"/>
      <Insert tool="graphite_rod_2" vessel="u_tube_1"/>
      <Attach vessel="u_tube_1" support="stand_1"/>
      <Attach vessel="graphite_rod_1" support="wire_1"/>
      <Attach vessel="graphite_rod_2" support="wire_2"/>
      <Attach vessel="wire_1" support="dc_power_1"/>
      <Attach vessel="wire_2" support="dc_power_1"/>
      <Attach vessel="switch_k1" support="dc_power_1"/>
      <Wait time="10s"/>
      <Insert tool="switch_k1" vessel="dc_power_1"/>
      <Wait time="120s"/>
      <Wait time="10s"/>
      <Attach vessel="graphite_rod_1" support="ammeter_1"/>
      <Attach vessel="graphite_rod_2" support="ammeter_1"/>
      <Attach vessel="switch_k2" support="ammeter_1"/>
      <Insert tool="switch_k2" vessel="ammeter_1"/>
      <Wait time="10s"/>
      <Attach vessel="graphite_rod_1" support="led_1"/>
      <Attach vessel="graphite_rod_2" support="led_1"/>
      <Attach vessel="switch_k2" support="led_1"/>
      <Insert tool="switch_k2" vessel="led_1"/>
      <Wait time="10s"/>
      <Attach vessel="graphite_rod_1" support="music_box_1"/>
      <Attach vessel="graphite_rod_2" support="music_box_1"/>
      <Attach vessel="switch_k2" support="music_box_1"/>
      <Insert tool="switch_k2" vessel="music_box_1"/>
      <Wait time="10s"/>
    </Procedure>
  </Synthesis>
</XDL>